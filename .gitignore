# Python
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/
venv/
.venv/
env/
.env/

# OS/IDEs
.DS_Store
.vscode/
.idea/

# Large simulation output data (optional to keep, but good to ignore if generated dynamically)
# * .csv files can be large, but if they are part of the dataset we can keep them.
# For now, let's track the code and docs.
*.csv
*.png

# Allow tracking dataset files
!Datasets/**/*.csv
!Datasets/**/*.png

# Allow tracking all results files
!Results/**/*.csv
!Results/**/*.png
